# Normalize line endings to LF in the repo; Git checks out as-is on all platforms
* text=auto eol=lf

# Python source files — always LF
*.py    text eol=lf
*.pyi   text eol=lf

# Config / data files — always LF
*.json  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.txt   text eol=lf
*.md    text eol=lf
*.toml  text eol=lf
*.cfg   text eol=lf
*.ini   text eol=lf
Makefile text eol=lf

# Shell scripts — LF only (CRLF breaks bash)
*.sh    text eol=lf

# Windows batch scripts — CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Binary files — no line ending conversion
*.parquet binary
*.csv     binary
*.png     binary
*.jpg     binary
*.jar     binary
*.zip     binary
